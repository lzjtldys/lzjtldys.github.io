e=65537
pbits = 512
p_high = c1 &gt;&gt; 256
for i in range(2**8):
     p4 = p_high&lt;&lt;8
     p4 = p4 + i
     kbits = pbits - p4.nbits()
     p4 = p4 &lt;&lt; kbits
     PR.&lt;x&gt; = PolynomialRing(Zmod(n))
     f = x + p4
     roots = f.small_roots(X=2^kbits, beta=0.4, epsilon=0.01)
     if roots:
         p = p4 + int(roots[0])
         print(p)
         break
  m = p^c1
  print(long_to_bytes(c1^p))       
</code></pre>
